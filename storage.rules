rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // receipts/ folder: authenticated access
    match /receipts/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // voice/ folder: authenticated access
    match /voice/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // documents/ folder: authenticated access
    match /documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Fallback: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
